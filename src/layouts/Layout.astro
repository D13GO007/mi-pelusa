---
interface Props {
	title?: string;
	pageNumber?: number | string;
	previousHref?: string | null;
	nextHref?: string | null;
}

const {
	title = 'Para Ti',
	pageNumber,
	previousHref = null,
	nextHref = null,
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}{pageNumber ? ` - Página ${pageNumber}` : ''}</title>
	</head>
	<body>
		<main class="page-shell">
			<div class="book-container">
				<header>
					<h1>{title}</h1>
					{pageNumber && <div class="page-number">Página {pageNumber}</div>}
				</header>

				<div class="page-content">
					<slot />
				</div>

				<footer>
					{
						previousHref ? (
							<a href={previousHref} class="nav-link">« Anterior</a>
						) : (
							<span class="nav-link disabled">« Anterior</span>
						)
					}
					{
						nextHref ? (
							<a href={nextHref} class="nav-link">Siguiente »</a>
						) : (
							<span class="nav-link disabled">Siguiente »</span>
						)
					}
				</footer>
			</div>
		</main>
	</body>
</html>

<style>
	:root {
		--bg-color: #fcfaf0;
		--text-color: #332f2c;
		--accent-color: #8c7851;
		--paper-shadow: rgba(58, 43, 23, 0.09);
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}

	body {
		background:
			radial-gradient(circle at top, rgba(255, 255, 255, 0.8), transparent 35%),
			linear-gradient(180deg, #f7f2de 0%, var(--bg-color) 55%, #f1ead5 100%);
		color: var(--text-color);
		font-family: 'Crimson Pro', serif;
	}

	.page-shell {
		display: flex;
		justify-content: center;
		padding: 24px 16px 48px;
		min-height: 100vh;
		box-sizing: border-box;
	}

	.book-container {
		width: min(100%, 680px);
		margin: 0 auto;
		padding: 32px 24px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(252, 248, 238, 0.95) 100%),
			var(--bg-color);
		box-shadow: 0 18px 40px var(--paper-shadow);
		position: relative;
		border: 1px solid #eae1d1;
		box-sizing: border-box;
	}

	@media (min-width: 768px) {
		.book-container {
			padding: 42px 52px;
		}

		.book-container::before {
			content: '';
			position: absolute;
			top: 0;
			left: 16px;
			bottom: 0;
			width: 2px;
			background: rgba(0, 0, 0, 0.04);
		}
	}

	header {
		text-align: center;
		border-bottom: 1px solid var(--accent-color);
		margin-bottom: 30px;
		padding-bottom: 10px;
	}

	h1 {
		font-size: 1.4rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--accent-color);
		margin: 0;
	}

	.page-number {
		margin-top: 8px;
		font-style: italic;
		color: #888;
		font-size: 0.95rem;
	}

	.page-content {
		font-size: 1.12rem;
		line-height: 1.85;
		text-align: justify;
	}

	.page-content :global(p) {
		margin: 0 0 1.5rem;
		text-indent: 1em;
	}

	.page-content :global(p:first-child) {
		margin-top: 0;
	}

	.page-content :global(.lead) {
		font-size: 1.24rem;
		color: #5f4b2d;
		text-indent: 0;
	}

	footer {
		margin-top: 42px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
		font-size: 1rem;
	}

	.nav-link {
		text-decoration: none;
		color: var(--accent-color);
		transition: opacity 0.2s ease;
	}

	.nav-link:hover {
		opacity: 0.7;
	}

	.disabled {
		color: #c5beb0;
		pointer-events: none;
	}

	@media (max-width: 480px) {
		.book-container {
			padding: 28px 20px;
		}

		.page-content {
			font-size: 1.04rem;
			line-height: 1.8;
		}

		footer {
			font-size: 0.95rem;
		}
	}
</style>
